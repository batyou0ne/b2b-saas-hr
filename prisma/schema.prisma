generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  memberships TenantMember[]
  leaveRequests LeaveRequest[]
  createdAt DateTime @default(now())
}

model Tenant {
  id        String   @id @default(uuid())
  name      String   // company name
  memberships TenantMember[]
  leaveRequests LeaveRequest[]
  createdAt DateTime @default(now())
}

enum Role {
  OWNER    // Şirketi kuran kişi (Fatura öder, herkesi yönetir)
  ADMIN    // Yönetici (İzinleri onaylayabilir)
  EMPLOYEE // Standart çalışan (Sadece kendi izinlerini görür)
}

model TenantMember {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())

  
  user      User     @relation(fields: [userId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  //bir kullanıcı aynı şirkete iki kere eklenemez
  @@unique([userId, tenantId])
}

enum RequestStatus {
  PENDING   
  APPROVED  
  REJECTED 
}

model LeaveRequest {
  id          String        @id @default(uuid())
  startDate   DateTime
  endDate     DateTime
  reason      String
  status      RequestStatus @default(PENDING)
  createdAt   DateTime      @default(now())

  // Foreign Keys 
  userId      String
  tenantId    String

  // Relations 
  user        User          @relation(fields: [userId], references: [id])
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
}